# Meridian backup — Restic + Cloudflare R2 runtime config
#
# Copy to /root/.meridian-backup.env on the VM and chmod 600.
# NEVER commit the filled-in version.
#
# LOSING RESTIC_PASSWORD = LOSING THE BACKUP. There is no recovery mechanism.
# Store a copy in a password manager before the first backup runs.

# R2 bucket name (for docs — the repo URL below is what actually gets used)
export MERIDIAN_BACKUP_BUCKET="meridian"

# Restic repo URL format: s3:<endpoint>/<bucket>/<prefix>
export RESTIC_REPOSITORY="s3:https://<ACCOUNT_ID>.r2.cloudflarestorage.com/<BUCKET>/restic"

# Restic encryption key. Generate once with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
export RESTIC_PASSWORD="REPLACE-WITH-RANDOM-TOKEN"

# Cloudflare R2 S3-compatible credentials (from R2 → Manage API Tokens).
# Token should be scoped to the single bucket with Object Read & Write.
export AWS_ACCESS_KEY_ID="REPLACE"
export AWS_SECRET_ACCESS_KEY="REPLACE"
