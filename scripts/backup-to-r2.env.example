# Meridian R2 backup — runtime configuration
#
# Copy to /root/.meridian-backup.env on the VM and `chmod 600` it.
# Never commit the filled-in version.

# R2 bucket name (created in the Cloudflare dashboard with versioning enabled).
MERIDIAN_BACKUP_BUCKET="meridian-backup"

# Optional: override the rclone remote name (default: meridian-r2).
# MERIDIAN_BACKUP_REMOTE="meridian-r2"
