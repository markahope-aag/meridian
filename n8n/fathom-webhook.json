{
  "name": "Fathom → Meridian Capture",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "fathom-inbound",
        "responseMode": "onReceived",
        "responseCode": 200,
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Fathom Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "fathom-inbound"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://meridian.markahope.com/capture/fathom",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.MERIDIAN_RECEIVER_TOKEN }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.body) }}",
        "options": {
          "response": {
            "response": {
              "fullResponse": true
            }
          },
          "timeout": 30000
        }
      },
      "id": "http-request",
      "name": "Forward to Meridian",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [480, 300],
      "onError": "continueRegularOutput"
    }
  ],
  "connections": {
    "Fathom Webhook": {
      "main": [
        [
          {
            "node": "Forward to Meridian",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "pinData": {},
  "settings": {
    "executionOrder": "v1"
  },
  "staticData": null,
  "tags": [
    {
      "name": "meridian"
    }
  ]
}
